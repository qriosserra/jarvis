# ── Discord ──────────────────────────────────────────────
# IMPORTANT: In addition to these credentials, you must enable these
# privileged Gateway Intents in the Discord Developer Portal
# (https://discord.com/developers/applications → your app → Bot):
#   • MESSAGE CONTENT INTENT  — required to read message text
#   • SERVER MEMBERS INTENT   — required for member lookup, rename,
#     move, mute, deafen, and voice speaker attribution
# Without these, the bot will crash at login with "Used disallowed intents".
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# ── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://jarvis:jarvis@localhost:5432/jarvis

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM provider routing ────────────────────────────────
LLM_INTERPRETATION_PROVIDER=xai
LLM_INTERPRETATION_MODEL=grok-3-mini
LLM_RESPONSE_PROVIDER=xai
LLM_RESPONSE_MODEL=grok-3-mini
LLM_EMBEDDING_PROVIDER=voyage
LLM_EMBEDDING_MODEL=voyage-4-lite

# OPENAI_API_KEY=
XAI_API_KEY=
VOYAGE_API_KEY=

# ── Speech-to-text ───────────────────────────────────────
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=

# ── Text-to-speech ───────────────────────────────────────
TTS_PROVIDER=cartesia
CARTESIA_API_KEY=

# ── Web research ─────────────────────────────────────────
RESEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# ── Persona ──────────────────────────────────────────────
DEFAULT_PERSONA=jarvis

# ── Observability ────────────────────────────────────────
# Set to enable OpenTelemetry tracing and metrics export
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Application ──────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
